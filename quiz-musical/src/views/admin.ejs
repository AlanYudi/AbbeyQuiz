<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Adicionar Música</title>

    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

    <div class="container">

        <h1>🎵 Adicionar Música</h1>

        <form method="POST">

            <input
                type="text"
                name="nome"
                placeholder="Digite o nome da música"
                required
            >

            <button type="submit">
                Adicionar
            </button>

        </form>

        <a href="/" class="voltar">
            ← Voltar
        </a>

    </div>

</body>
</html>